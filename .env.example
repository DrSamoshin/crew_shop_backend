# Copy to .env.dev for local development (.env.* is git-ignored).

# Environment: dev | stage | prod
ENV=dev
LOG_LEVEL=INFO

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
WORKERS=4

# crew_auth (platform identity provider). CREW_AUTH_SERVICE_NAME must match the
# RETURN_URIS_<SERVICE> key registered with crew_auth for this environment.
CREW_AUTH_URL=https://auth.crewservices.org
CREW_AUTH_SERVICE_NAME=crew_shop

# Admin S2S shared service token (crew_admin -> /v1/admin/catalog). Unset disables the admin API.
ADMIN_SERVICE_TOKEN=

# Database: one complete async DSN in every environment. In the cluster it arrives
# from the crew-shop-db Secret.
DATABASE_URL=postgresql+asyncpg://crew_shop:crew_shop@localhost:5432/crew_shop_db
