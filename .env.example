# Copy to .env.dev for local development (.env.* is git-ignored).

# Environment: dev | stage | prod
ENV=dev
LOG_LEVEL=INFO

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
WORKERS=4

# OAuth providers (server-side ID-token verification)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Database (dev): single async connection string
DATABASE_URL=postgresql+asyncpg://crew_shop:crew_shop@localhost:5432/crew_shop_db

# Database (stage/prod): Cloud SQL connection parts (leave unset in dev)
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=
# DATABASE_HOST=
